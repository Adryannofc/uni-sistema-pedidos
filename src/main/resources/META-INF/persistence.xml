<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             version="3.0"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="deliveryPU" transaction-type="RESOURCE_LOCAL">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- ENTIDADES -->
        <class>com.pedidos.model.entity.Usuario</class>
        <class>com.pedidos.model.entity.Admin</class>
        <class>com.pedidos.model.entity.Cliente</class>
        <class>com.pedidos.model.entity.Restaurante</class>
        <class>com.pedidos.model.entity.Endereco</class>
        <class>com.pedidos.model.entity.CategoriaGlobal</class>
        <class>com.pedidos.model.entity.CategoriaCardapio</class>
        <class>com.pedidos.model.entity.Produto</class>
        <class>com.pedidos.model.entity.Pedido</class>
        <class>com.pedidos.model.entity.ItemPedido</class>
        <class>com.pedidos.model.entity.AreaEntrega</class>
        <class>com.pedidos.model.entity.HorarioFuncionamento</class>
        <properties>

            <!-- JDBC LOCAL -->

            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/deliveryapp"/> <!--url padrão(modificar para database utilizada)-->
            <property name="jakarta.persistence.jdbc.user" value="postgres"/> <!--user padrão(modificar)-->
            <property name="jakarta.persistence.jdbc.password" value="postgres"/> <!--password padrão(modificar)-->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>

            <!-- Hibernate (Flyway cria, Hibernate valida)-->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="validate"/>
            <property name="hibernate.show_sql" value="false"/>

        </properties>

    </persistence-unit>
</persistence>