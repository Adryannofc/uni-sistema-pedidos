<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             version="3.0"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="deliveryPU" transaction-type="RESOURCE_LOCAL">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- ENTIDADES -->
        <class>com.pedidos.domain.model.Usuario</class>
        <class>com.pedidos.domain.model.Admin</class>
        <class>com.pedidos.domain.model.Cliente</class>
        <class>com.pedidos.domain.model.Restaurante</class>
        <class>com.pedidos.domain.model.Produto</class>
        <class>com.pedidos.domain.model.CategoriaGlobal</class>
        <class>com.pedidos.domain.model.CategoriaCardapio</class>
        <class>com.pedidos.domain.model.Pedido</class>
        <class>com.pedidos.domain.model.ItemPedido</class>

        <properties>

            <!-- JDBC LOCAL -->
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/delivery_db"/> <!--url padrão(modificar para database utilizada)-->
            <property name="jakarta.persistence.jdbc.user" value="postgres"/> <!--user padrão(modificar)-->
            <property name="jakarta.persistence.jdbc.password" value="1234"/> <!--password padrão(modificar)-->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>

            <!-- Hibernate (Flyway cria, Hibernate valida)-->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="validate"/>

            <!-- Debug -->
            <property name="hibernate.show_sql" value="true"/>

        </properties>

    </persistence-unit>
</persistence>